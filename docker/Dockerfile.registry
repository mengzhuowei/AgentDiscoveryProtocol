# Stage 1: Install dependencies
ARG ALPINE_MIRROR=docker.io/library/node
ARG NPM_MIRROR=https://registry.npmjs.org

FROM ${ALPINE_MIRROR}:20-alpine AS deps
WORKDIR /app
COPY package*.json ./
RUN npm config set registry ${NPM_MIRROR} && \
    npm ci --omit=dev || npm install --omit=dev

# Stage 2: TypeScript build
FROM ${ALPINE_MIRROR}:20-alpine AS builder

WORKDIR /app

COPY package*.json ./
RUN npm config set registry ${NPM_MIRROR} && \
    npm ci

COPY tsconfig.json ./
COPY src ./src/
COPY start-registry.ts ./
COPY schema.sql ./

RUN npx tsc

# Stage 3: Runtime image
FROM ${ALPINE_MIRROR}:20-alpine AS runtime

WORKDIR /app

RUN apk add --no-cache dumb-init

COPY --from=deps /app/node_modules ./node_modules
COPY --from=builder /app/dist ./dist
COPY --from=builder /app/start-registry.js ./
COPY --from=builder /app/schema.sql ./
COPY docker/registry-config.json ./config.json

RUN addgroup -g 1001 -S nodejs && \
    adduser  -S nodejs -u 1001 -G nodejs && \
    chown -R nodejs:nodejs /app

USER nodejs

EXPOSE 3000

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
  CMD wget -qO- http://localhost:3000/health || exit 1

ENTRYPOINT ["dumb-init", "--", "node", "start-registry.js"]