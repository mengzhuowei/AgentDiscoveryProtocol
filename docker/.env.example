# ADP Docker Environment Configuration
# Copy this file to .env and update the values as needed

# ==============================================
# Registry Service
# ==============================================
REGISTRY_PORT=3800
REGISTRY_HOST=0.0.0.0

# ==============================================
# MySQL Database
# ==============================================
MYSQL_ROOT_PASSWORD=change_this_root_password
MYSQL_DATABASE=adp_registry
MYSQL_USER=adp
MYSQL_PASSWORD=change_this_mysql_password
MYSQL_HOST=mysql
MYSQL_PORT=3306

# ==============================================
# Redis Cache
# ==============================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ==============================================
# Registration Settings
# ==============================================
REGISTRATION_TTL=86400
MAX_AGENTS=10000

# ==============================================
# Authentication
# ==============================================
TOKEN_ENABLED=false

# ==============================================
# Relay Service
# ==============================================
RELAY_PORT=3900
RELAY_HOST=0.0.0.0
# RELAY_TLS_CERT=  # PEM-encoded TLS certificate
# RELAY_TLS_KEY=   # PEM-encoded TLS private key
RELAY_MAX_CONNECTIONS=10000
RELAY_HEARTBEAT_INTERVAL_MS=15000
RELAY_HEARTBEAT_TIMEOUT_MS=45000
RELAY_OFFLINE_MAX_AGE_MS=86400000
RELAY_OFFLINE_MAX_PER_AGENT=500

# ==============================================
# CORS
# ==============================================
CORS_ENABLED=false
CORS_ORIGINS=*

# Docker 镜像配置
# 使用国内镜像加速构建

# Docker 镜像仓库（用于 alpine 基础镜像）
# DOCKER_MIRROR=registry.docker-cn.com

# npm 镜像配置（用于 npm install/ci）
# NPM_MIRROR=https://registry.npmmirror.com

# Docker 构建时使用镜像
# DOCKER_BUILDKIT=1