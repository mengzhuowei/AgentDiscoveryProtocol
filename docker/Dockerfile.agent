# Stage 1: Install dependencies
ARG ALPINE_MIRROR
FROM ${ALPINE_MIRROR:-node}:20-alpine AS deps
WORKDIR /app
COPY package*.json ./
RUN npm config set registry ${NPM_MIRROR:-https://registry.npmjs.org} && \
    npm ci --omit=dev || npm install --omit=dev

# Stage 2: TypeScript build
FROM ${ALPINE_MIRROR:-node}:20-alpine AS builder

WORKDIR /app

COPY package*.json ./
RUN npm config set registry ${NPM_MIRROR:-https://registry.npmjs.org} && \
    npm ci

COPY tsconfig.json ./
COPY src ./src/
COPY start.ts ./
COPY chat.ts ./

RUN npx tsc

# Stage 3: Runtime image
FROM ${ALPINE_MIRROR:-node}:20-alpine AS runtime

WORKDIR /app

RUN apk add --no-cache dumb-init

COPY --from=deps /app/node_modules ./node_modules
COPY --from=builder /app/dist ./dist
COPY --from=builder /app/start.js ./
COPY --from=builder /app/chat.js ./

RUN mkdir -p /app/.adp/keys && \
    addgroup -g 1001 -S nodejs && \
    adduser  -S nodejs -u 1001 -G nodejs && \
    chown -R nodejs:nodejs /app

USER nodejs

EXPOSE 9900

ENTRYPOINT ["dumb-init", "--", "node", "start.js"]