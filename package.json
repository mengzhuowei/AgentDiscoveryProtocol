{
  "name": "adp-agent",
  "version": "0.2.4",
  "description": "Agent Discovery Protocol (ADP) - discover, query, and ping agents via MCP / OpenClaw",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "bin": {
    "adp-agent": "dist/start-mcp.js",
    "adp-registry": "dist/start-registry.js",
    "adp-relay": "dist/start-relay.js"
  },
  "files": [
    "dist/",
    "skill/",
    "schema.sql",
    "config.example.json"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "start": "npx ts-node start.ts",
    "chat": "npx ts-node chat.ts",
    "relay": "npx ts-node start-relay.ts",
    "registry": "npx ts-node start-registry.ts",
    "adp": "npx ts-node start-mcp.ts",
    "example:openclaw": "npx ts-node examples/openclaw-agent.ts",
    "example:video-client": "npx ts-node examples/video-client.ts",
    "test:integration": "npx ts-node tests/integration/integration-test.ts",
    "test:relay": "npx ts-node tests/integration/relay-test.ts",
    "test:mdns": "npx ts-node tests/integration/mdns-test.ts",
    "test:capability": "npx ts-node tests/integration/capability-test.ts",
    "test:task": "npx ts-node tests/integration/task-test.ts",
    "test:contacts": "npx ts-node tests/integration/contacts-test.ts",
    "test:registry": "npx ts-node tests/integration/test-registry.ts",
    "test:auth": "npx ts-node tests/integration/test-auth.ts",
    "test:key-rotation": "npx ts-node tests/integration/test-key-rotation.ts",
    "test:webhook": "npx ts-node tests/webhook/test-webhook.ts",
    "test:webhook-flow": "npx ts-node tests/webhook/test-full-flow.ts",
    "dev": "tsc --watch & nodemon dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest tests/unit",
    "test:integration:jest": "jest tests/integration",
    "test:e2e": "jest tests/e2e",
    "docs:generate": "typedoc",
    "docs:clean": "rm -rf docs/api && typedoc",
    "docs:watch": "typedoc --watch"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "multicast-dns": "^7.2.5",
    "mysql2": "^3.22.3",
    "redis": "^5.12.1",
    "selfsigned": "^2.4.1",
    "tweetnacl": "^1.0.3",
    "ws": "^8.17.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/jest": "^29.5.12",
    "@types/multicast-dns": "^7.2.4",
    "@types/node": "^20.12.7",
    "@types/selfsigned": "^2.0.4",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^7.7.0",
    "@typescript-eslint/parser": "^7.7.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "ts-jest": "^29.1.2",
    "ts-mockito": "^2.6.1",
    "ts-node": "^10.9.2",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.11.0",
    "typescript": "^5.4.5"
  },
  "keywords": [
    "adp",
    "agent",
    "discovery",
    "protocol",
    "mcp",
    "model-context-protocol",
    "openclaw",
    "agent-discovery",
    "p2p",
    "mdns",
    "websocket"
  ],
  "author": "mengzhuowei@qq.com",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mengzhuowei/AgentDiscoveryProtocol.git"
  },
  "bugs": {
    "url": "https://github.com/mengzhuowei/AgentDiscoveryProtocol/issues"
  },
  "homepage": "https://github.com/mengzhuowei/AgentDiscoveryProtocol#readme"
}
